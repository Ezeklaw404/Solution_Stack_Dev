@page "/reviews"
@rendermode InteractiveServer

@using System.Text.Json
@using System.Text.Json.Serialization;

@inject IHttpClientFactory HttpClientFactory
@inject IConfiguration Configuration

<PageTitle>Reviews</PageTitle>

<h1 class="mb-3">Reviews</h1>

@if (loading)
{
    <div class="d-flex align-items-center gap-3 py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading reviews...</span>
        </div>
        <span>Loading reviews...</span>
    </div>
}
else
{
    <div class="container-fluid px-0">
        <div class="row g-4">
            @foreach (var review in _reviews)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card h-100 shadow-sm border-0 review-card">
                        <div class="card-img-top review-card-img-wrap d-flex justify-content-center align-items-center bg-light">
                            <img src="@review.ImageUrl"
                                 class="review-avatar img-fluid"
                                 alt="Photo of @review.Id"
                                 loading="lazy" />
                        </div>
                        <div class="card-body text-center d-flex flex-column">
                            <h5 class="card-title fw-semibold mb-2">@review.Id</h5>
                            <div class="review-stars mb-1" aria-label="Rating: @review.Stars out of 5">
                                @for (var star = 1; star <= 5; star++)
                                {
                                    <span class="review-star @(star <= review.Stars ? "filled" : string.Empty)">&#9733;</span>
                                }
                            </div>
                            <p class="text-muted small mb-0 mt-auto">@review.Stars / 5</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {

    private HttpClient _http;
    private bool loading = true;
    private List<Review> _reviews = new();

    // source documentation
    // https:developers.thecatapi.com/view-account/ylX4blBYT9FaoVd6OhvR?report=bOoHBz-8t
    const int COUNT = 10;
    string baseUrl = $"https://api.thecatapi.com/v1/images/search";
    // string url = "https://api.thecatapi.com/v1/images/search?limit=10";

    protected override async Task OnInitializedAsync()
    {
        _http = new HttpClient();
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        string tempUrl = $"{baseUrl}?limit={COUNT}";


        _reviews = await _http.GetFromJsonAsync<List<Review>>(tempUrl);
        Random random = new Random();
        foreach (var review in _reviews)
        {
            review.Stars = random.Next(1, 6);
        } 
        loading = false;
    }          

